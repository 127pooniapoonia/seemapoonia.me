---
import SectionLabel from './SectionLabel.astro';
---

<section id="contact" class="py-24 bg-surface">
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal">
      <SectionLabel number="04" />
      <h2 class="font-display text-5xl md:text-6xl text-gray-900 mb-16">
        Contact Me
      </h2>
    </div>

    <div class="grid md:grid-cols-5 gap-12">
      <!-- Left: info -->
      <div class="md:col-span-2 reveal">
        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">Email</h3>
        <a
          href="mailto:seema.127poonia@gmail.com?subject=Hi Seema — from seemapoonia.me"
          class="text-sm text-gray-700 hover:text-brand transition-colors break-all"
        >
          seema.127poonia@gmail.com
        </a>

        <h3 class="text-xs font-bold uppercase tracking-widest text-gray-400 mt-8 mb-4">
          Social
        </h3>
        <div class="flex gap-5">
          <a
            href="https://github.com/127pooniapoonia"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Seema Poonia on GitHub"
            class="text-gray-500 hover:text-brand transition-colors"
          >
            <!-- GitHub icon -->
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/seema-poonia/"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Seema Poonia on LinkedIn"
            class="text-gray-500 hover:text-brand transition-colors"
          >
            <!-- LinkedIn icon -->
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Right: form -->
      <form
        id="contact-form"
        class="md:col-span-3 space-y-4 reveal"
        novalidate
      >
        <div>
          <label for="name" class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">
            Name
          </label>
          <input
            type="text"
            id="name"
            name="name"
            required
            minlength="2"
            placeholder="Your name"
            class="w-full border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:border-brand transition-colors"
          />
        </div>
        <div>
          <label for="email" class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">
            Email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="your@email.com"
            class="w-full border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:border-brand transition-colors"
          />
        </div>
        <div>
          <label for="phone" class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">
            Phone <span class="normal-case text-gray-400 tracking-normal">(optional)</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="+91 98765 43210"
            class="w-full border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:border-brand transition-colors"
          />
        </div>
        <div>
          <label for="message" class="block text-xs font-bold uppercase tracking-widest text-gray-500 mb-1">
            Message
          </label>
          <textarea
            id="message"
            name="message"
            required
            rows="4"
            placeholder="What's on your mind?"
            class="w-full border border-gray-200 px-4 py-3 text-sm focus:outline-none focus:border-brand transition-colors resize-none"
          ></textarea>
        </div>
        <button
          id="submit-btn"
          type="submit"
          class="w-full bg-brand hover:bg-brand-dark text-white text-xs font-bold uppercase tracking-widest py-4 transition-colors duration-200 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Send Message
        </button>
        <p id="form-success" class="hidden text-sm text-green-600 font-medium">
          Message sent! I'll get back to you soon.
        </p>
        <p id="form-error" class="hidden text-sm text-red-600 font-medium">
          Something went wrong. Please try again or email me directly.
        </p>
      </form>

      <script>
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
        const ok   = document.getElementById('form-success') as HTMLParagraphElement;
        const err  = document.getElementById('form-error') as HTMLParagraphElement;

        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          ok.classList.add('hidden');
          err.classList.add('hidden');
          btn.textContent = 'Sending…';
          btn.disabled = true;

          try {
            const res = await fetch('/api/contact', {
              method: 'POST',
              body: new FormData(form),
            });
            if (res.ok) {
              ok.classList.remove('hidden');
              form.reset();
            } else {
              const data = await res.json().catch(() => ({}));
              err.textContent = data.error ?? 'Something went wrong. Please try again or email me directly.';
              err.classList.remove('hidden');
            }
          } catch {
            err.classList.remove('hidden');
          } finally {
            btn.textContent = 'Send Message';
            btn.disabled = false;
          }
        });
      </script>
    </div>
  </div>
</section>
