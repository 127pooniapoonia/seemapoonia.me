---
const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white py-8">
  <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-gray-400">
    <p>© {year} Seema Poonia. All rights reserved.</p>
    <div class="flex gap-6">
      <a
        href="https://github.com/127pooniapoonia"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brand transition-colors"
        aria-label="GitHub"
      >
        GitHub
      </a>
      <a
        href="https://www.linkedin.com/in/seema-poonia/"
        target="_blank"
        rel="noopener noreferrer"
        class="hover:text-brand transition-colors"
        aria-label="LinkedIn"
      >
        LinkedIn
      </a>
      <a href="#home" class="hover:text-brand transition-colors" aria-label="Back to top">
        ↑ Top
      </a>
    </div>
  </div>
</footer>
