---
---

<section
  id="home"
  class="relative h-screen bg-cover bg-center bg-no-repeat flex items-center justify-center"
  style="background-image: url('/img/bg-cover.jpg')"
>
  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-black/55"></div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6">
    <p class="text-brand text-xs font-bold uppercase tracking-[0.3em] mb-6">
      Sr. Frontend Engineer &amp; Tech Lead
    </p>
    <h1 class="font-display text-6xl md:text-8xl font-bold text-white leading-none mb-6">
      Seema Poonia
    </h1>
    <p class="text-white/70 text-base md:text-lg tracking-wide max-w-md mx-auto mb-10">
      Building teams, products, and the architecture that makes shipping possible.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="#projects"
        class="inline-block bg-brand hover:bg-brand-dark text-white text-xs font-bold uppercase tracking-widest px-8 py-4 transition-colors duration-200"
      >
        View My Work
      </a>
      <a
        href="/img/Seema_Poonia_Senior_Frontend_Developer_Resume.pdf"
        download
        class="inline-block border border-white/60 hover:border-brand hover:text-brand text-white text-xs font-bold uppercase tracking-widest px-8 py-4 transition-colors duration-200"
      >
        Download CV
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/40">
    <span class="text-[10px] uppercase tracking-widest">Scroll</span>
    <div class="w-px h-8 bg-white/30"></div>
  </div>
</section>
