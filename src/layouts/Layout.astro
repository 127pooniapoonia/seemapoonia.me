---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Seema Poonia — Sr. Frontend Engineer & Tech Lead',
  description = 'Sr. Frontend Engineer & Tech Lead at Electrum. 6+ years building and leading frontend products — React, Angular, TypeScript. Available for senior and lead roles.',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/img/seema_cover.png', Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/img/favicon.ico" type="image/x-icon" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400;700;900&family=Open+Sans:wght@400;600;700&family=Playfair+Display:wght@400;700;900&display=swap"
      rel="stylesheet"
    />

    <!-- Preload hero background -->
    <link rel="preload" as="image" href="/img/bg-cover.jpg" />

    <!-- Google Analytics 4 — replace G-XXXXXXXX with your measurement ID -->
    <!-- <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXXX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-XXXXXXXX');
    </script> -->

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Seema Poonia",
        "jobTitle": "Sr. Frontend Engineer & Tech Lead",
        "url": "https://seemapoonia.me",
        "email": "seema@electrum.co",
        "sameAs": [
          "https://github.com/127pooniapoonia",
          "https://www.linkedin.com/in/seema-poonia/"
        ]
      }
    </script>
  </head>

  <body class="font-sans text-gray-800 antialiased">
    <slot />
  </body>
</html>
